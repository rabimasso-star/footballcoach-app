generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Coach {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  club      String?
  createdAt DateTime @default(now())

  teams     Team[]
  drills    Drill[]
  sessions  TrainingSession[]
}

model Team {
  id                  String   @id @default(cuid())
  coachId             String
  name                String
  ageGroup            String
  competitionLevel    String
  primaryFormation    String?
  trainingDaysPerWeek Int?
  primaryGoals        String?
  formationLayout     Json?

  coach    Coach   @relation(fields: [coachId], references: [id])
  players  Player[]
  sessions TrainingSession[]
}

model Player {
  id           String              @id @default(cuid())
  teamId       String
  name         String
  dateOfBirth  DateTime?
  positions    String?
  dominantFoot String?
  notes        String?

  team       Team               @relation(fields: [teamId], references: [id])
  attributes PlayerAttributeSet?
}

model PlayerAttributeSet {
  playerId       String @id
  speed          Int
  endurance      Int
  strength       Int
  dribbling      Int
  passing        Int
  shooting       Int
  firstTouch     Int
  tackling       Int
  positioning    Int
  decisionMaking Int
  confidence     Int
  attitude       Int
  strengths      String?
  weaknesses     String?

  player Player @relation(fields: [playerId], references: [id])
}

model Drill {
  id          String               @id @default(cuid())
  name        String
  description String?
  objectives  String?
  category    String
  focusTags   String?
  difficulty  Int
  minPlayers  Int
  maxPlayers  Int
  durationMin Int
  intensity   Int
  equipment   String?
  pitchArea   String?
  ageMin      Int?
  ageMax      Int?
  imageUrl    String?
  layout      Json?

  coachId     String?
  coach       Coach?               @relation(fields: [coachId], references: [id])
  blockDrills TrainingBlockDrill[]

  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model TrainingSession {
  id              String            @id @default(cuid())
  teamId          String
  coachId         String
  date            DateTime
  title           String
  mainFocusTags   String?
  durationMinutes Int
  intensity       Int
  createdBy       String
  createdAt       DateTime          @default(now())

  team     Team              @relation(fields: [teamId], references: [id])
  coach    Coach             @relation(fields: [coachId], references: [id])
  blocks   TrainingBlock[]
  feedback SessionFeedback[]
}

model TrainingBlock {
  id              String               @id @default(cuid())
  sessionId       String
  type            String
  order           Int
  durationMinutes Int
  focusTags       String?
  description     String?

  session         TrainingSession      @relation(fields: [sessionId], references: [id])
  drills          TrainingBlockDrill[]
}

model TrainingBlockDrill {
  id                   String        @id @default(cuid())
  blockId              String
  drillId              String
  order                Int
  customNotes          String?
  adjustmentForPlayers String?
  aiSuggestions        String?

  block TrainingBlock @relation(fields: [blockId], references: [id])
  drill Drill         @relation(fields: [drillId], references: [id])
}

model SessionFeedback {
  id         String          @id @default(cuid())
  sessionId  String
  playerId   String?
  whatWorked String?
  whatDidnt  String?
  notes      String?

  session TrainingSession @relation(fields: [sessionId], references: [id])
}